[alias]
	ci = commit
	co = checkout
	cp = cherry-pick
	df = diff
	st = --paginate status --branch --short
	tip = log --no-walk --stat
[color]
	ui = auto
[core]
	abbrev = 8
	autocrlf = false
	editor = vim
	pager = less -FRX
	quotepath = false
	safecrlf = true
[grep]
	lineNumber = true
[log]
	decorate = short
[pull]
	ff = only
[push]
	default = simple
